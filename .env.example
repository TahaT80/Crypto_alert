# نمونه فایل env — این فایل را کپی کنید و با نام .env ذخیره کنید
# (در ویندوز: copy .env.example .env)
# (در لینوکس/مک: cp .env.example .env)

# (اجباری) توکن ربات تلگرام از @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# (اختیاری) کلید سرویس chart-img.com برای چارت تکنیکال
# از https://chart-img.com بگیرید
CHART_API_KEY=your_chart_img_api_key_here

# (اختیاری) کلید CoinMarketCap — در حال حاضر استفاده نمی‌شود
CMC_API_KEY=your_cmc_api_key_here
