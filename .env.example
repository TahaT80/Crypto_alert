# === Telegram Bot Token (الزامی) ===
# از BotFather بگیرید: https://t.me/BotFather
TELEGRAM_TOKEN=

# === Chart-Img - چارت تکنیکال (اختیاری) ===
# از https://chart-img.com بگیرید - بدون کلید، فقط متن قیمت نمایش داده می‌شود
CHART_API_KEY=

# === CoinMarketCap (اختیاری) ===
CMC_API_KEY=

# === زمان‌بندی ===
TIMEZONE=Asia/Tehran

# === اشتراک (اختیاری) ===
# آیدی تلگرام ادمین برای ارتقای پلن (نمایش به کاربران)
ADMIN_CONTACT=@admin

# === ادمین‌های ربات (برای /grant, /revoke, /userinfo) ===
# آیدی عددی تلگرام — مثلاً: ADMIN_IDS=123456789,987654321
# چند آیدی با کاما جدا کنید
ADMIN_IDS=
